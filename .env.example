# Required for Telegram delivery. If missing, local/manual runs still print the briefing.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional AI summarization. If missing, Jarvis uses the free extractive fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional source APIs. Missing credentials are skipped safely.
YOUTUBE_API_KEY=
TMDB_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=jarvis-briefing-agent/0.1

# Optional storage. SQLite is the default fallback.
STORAGE_PROVIDER=sqlite
SQLITE_DB_PATH=data/jarvis.sqlite3
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional runtime config override.
# Set provider to supabase after creating public.runtime_configs and saving an active config row.
RUNTIME_CONFIG_PROVIDER=none
RUNTIME_CONFIG_ID=active
RUNTIME_CONFIG_PATH=
RUNTIME_CONFIG_JSON=

# Cloudflare Pages Functions. Set these in Cloudflare, not in frontend code.
JARVIS_ADMIN_TOKEN=
GITHUB_ACTIONS_TOKEN=
GITHUB_REPOSITORY=HarishRaja10/jarvis-agent
GITHUB_WORKFLOW_FILE=manual-briefing.yml
GITHUB_WORKFLOW_REF=main

# Optional voice briefing. Text delivery never depends on voice success.
VOICE_PROVIDER=none
PIPER_BIN=
PIPER_MODEL=
EDGE_TTS_VOICE=en-GB-RyanNeural
FFMPEG_BIN=ffmpeg
